# =============================================================================
# pumpswap_trade_with_safekey 本地环境变量（勿提交，按需修改）
# =============================================================================

APP_ENV=prod
BUY_SOL_AMOUNT=0.01

# 代币 mint（也可命令行传入 ./run.sh <MINT>）
MINT=

# keystore 密码（不设则交互输入）
KEYSTORE_PASSWORD=

# RPC（强烈建议设置：公网 api.mainnet-beta.solana.com 易卡顿）
SOLANA_RPC_URL=http://fr.rpc.gadflynode.com:80

# 多 SWQoS 时必填：durable nonce 账户地址（配置 2 个及以上 SWQoS 时需设置，否则买入会报错）
# NONCE_ACCOUNT=
