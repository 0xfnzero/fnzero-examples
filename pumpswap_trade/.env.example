# =============================================================================
# pumpswap_trade 本地环境变量（勿提交，按需修改）
# =============================================================================

# 环境：dev 或 prod（对应 config/dev 或 config/prod 目录）
# 此处的配置优先级高于 config 中的配置
APP_ENV=prod

# 代币 mint（也可命令行传入 ./run.sh <MINT>）
MINT=

# 钱包私钥（支持标准 64 字节数组 JSON 或 base58 格式）
PRIVATE_KEY=

# RPC 节点地址（强烈建议设置：公网 api.mainnet-beta.solana.com 易卡顿）
SOLANA_RPC_URL=

# 买入 SOL 数量
BUY_SOL_AMOUNT=0.01

# SWQoS 配置（优先级高于 config 中的配置）
# SWQoS 区域：NewYork, Frankfurt, Amsterdam, SLC, Tokyo, London, LosAngeles
SWQOS_REGION=Frankfurt

# 各 SWQoS 提供商的 API Token（需要哪个就填写哪个）
SWQOS_ASTRALANE_TOKEN=
SWQOS_BLOCKRAZOR_TOKEN=
SWQOS_JITO_TOKEN=
SWQOS_NEXTBLOCK_TOKEN=
SWQOS_BLOXROUTE_TOKEN=
SWQOS_ZEROSLOT_TOKEN=
SWQOS_TEMPORAL_TOKEN=
SWQOS_FLASHBLOCK_TOKEN=
SWQOS_NODE1_TOKEN=
SWQOS_STELLIUM_TOKEN=
SWQOS_SPEEDLANDING_TOKEN=
SWQOS_SOYAS_TOKEN=

# 多 SWQoS 时必填：durable nonce 账户地址（配置 2 个及以上 SWQoS 时需设置，否则买入会报错）
NONCE_ACCOUNT=
