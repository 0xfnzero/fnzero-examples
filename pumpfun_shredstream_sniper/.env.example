# PumpFun ShredStream sniper example.
# This example uses PRIVATE_KEY directly and does not use sol-safekey.

PRIVATE_KEY=
RPC_URL=https://api.mainnet-beta.solana.com

# Local Jito ShredStream proxy endpoint.
SHREDSTREAM_ENDPOINT=http://127.0.0.1:10800

# Sniper behavior.
# Default waits for create+first buy. Set false to buy the first observed PumpFun buy event.
REQUIRE_CREATED_BUY=true
TARGET_MINT=
BUY_SOL_AMOUNT=0.01
# with_max_input is recommended for sniping. exact_input spends a fixed SOL amount
# and protects minimum token output, which can fail more often in fast markets.
BUY_MODE=with_max_input
BUY_SLIPPAGE_BPS=300
SELL_SLIPPAGE_BPS=500
HOLD_SECONDS=3
# Reject queued/delayed events before building a transaction.
MAX_EVENT_AGE_MS=1000
WAIT_TX_CONFIRMED=true
WAIT_FOR_ALL_SUBMITS=false
# Set true only when every required ATA was prepared before the event arrived.
ASSUME_PREPARED_ATAS=false
